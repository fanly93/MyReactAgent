{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read(react_agent/**)",
      "Read(tests/**)",
      "Read(examples/**)",
      "Read(pyproject.toml)",
      "Read(CLAUDE.md)",
      "Bash(python -m pytest tests/ -v)",
      "Bash(python -m pytest tests/ -v -m *)",
      "Bash(python examples/*.py)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(python -c *)",
      "Bash(python -m py_compile *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git reset --hard *)",
      "Bash(pip uninstall *)",
      "Read(.env)",
      "Read(**/.env)"
    ]
  },
  "model": "claude-sonnet-4-6",
  "teammates": {
    "displayMode": "auto"
  }
}
