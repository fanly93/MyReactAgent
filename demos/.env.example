# ============================================================
# MyReactAgent Demo — API Key 配置模板
# 复制为 .env 并填入真实值：cp .env.example .env
# ============================================================

# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=              # 留空使用官方地址

# ── DeepSeek ────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── DashScope（阿里云 Qwen）────────────────────────────────
DASHSCOPE_API_KEY=sk-...
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── Google Gemini（OpenAI 兼容模式）────────────────────────
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ── Anthropic Claude（原生 SDK）──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── 工具 API Keys ────────────────────────────────────────────
TAVILY_API_KEY=tvly-...
OPENWEATHERMAP_API_KEY=...

# ── 演示默认提供商（优先级：deepseek > openai > dashscope > gemini）
# DEMO_DEFAULT_PROVIDER=deepseek
